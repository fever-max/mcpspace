{
  "name": "@mcpspace/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "mcpspace Desktop",
  "author": "mcpspace",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -b --pretty false",
    "package": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@mcpspace/adapters": "file:../../packages/adapters",
    "@mcpspace/core": "file:../../packages/core",
    "@mcpspace/reconciler": "file:../../packages/reconciler",
    "@mcpspace/shared": "file:../../packages/shared",
    "@mcpspace/workspace": "file:../../packages/workspace"
  },
  "devDependencies": {
    "electron": "42.3.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0"
  },
  "build": {
    "appId": "com.mcpspace.desktop",
    "productName": "mcpspace Desktop",
    "directories": {
      "output": "dist",
      "buildResources": "../../assets/img"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "asar": true,
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "win": {
      "icon": "logo.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
