{
    "name":  "mcpspace",
    "version":  "0.1.1",
    "readme":  "apps/cli/README.md",
    "packageManager":  "pnpm@9.0.0",
    "workspaces":  [
                       "apps/*",
                       "packages/*"
                   ],
    "scripts":  {
                    "build":  "tsc -b",
                    "typecheck":  "tsc -b --pretty false",
                    "desktop:dev":  "node scripts/run-desktop-dev.cjs",
                    "desktop:build":  "npm --workspace @mcpspace/desktop run build",
                    "desktop:typecheck":  "npm --workspace @mcpspace/desktop run typecheck"
                },
    "bin":  {
                "mcpspace":  "apps/cli/dist/index.js"
            },
    "files":  [
                  "apps/cli/dist/**",
                  "apps/cli/package.json",
                  "apps/cli/README.md",
                  "packages/*/dist/**",
                  "packages/*/package.json",
                  "README.md"
              ],
    "dependencies":  {
                         "@iarna/toml":  "^2.2.5",
                         "@mcpspace/adapters":  "file:packages/adapters",
                         "@mcpspace/core":  "file:packages/core",
                         "@mcpspace/reconciler":  "file:packages/reconciler",
                         "@mcpspace/shared":  "file:packages/shared",
                         "@mcpspace/workspace":  "file:packages/workspace",
                         "commander":  "^12.1.0",
                         "yaml":  "^2.5.0",
                         "zod":  "^3.23.8"
                     },
    "devDependencies":  {
                            "@types/node":  "^22.10.2",
                            "typescript":  "^5.5.4"
                        }
}
